# Dependency (File library yang berat, nanti di-install ulang pakai npm install)
node_modules/

# Environment Variables (Rahasianya ada di sini!)
.env

# Moodle backup & database dumps (jangan di-push)
*.mbz
*.sql

# Tapi schema & migration SQL tetap di-track
!backend/schema.sql
!backend/migrations/
!backend/migrations/*.sql

# Uploads (gambar soal yang di-upload user)
backend/uploads/questions/*
!backend/uploads/questions/.gitkeep
backend/uploads/.gitkeep

# Uploads materi (file PDF, DOCX, dll yang di-upload guru)
backend/uploads/materi/*
!backend/uploads/materi/.gitkeep

# Sisa ekstraksi .mbz (temporary extraction directories)
mbz_extracted/

# Session & log files dari AI tools
session-ses_*.md
*.xml
!backend/schema.sql

# Analisis script sementara
backend/analyze_mbz.js

# Build artifacts Next.js
frontend/.next/

# Lock files yang tidak perlu
skills-lock.json
